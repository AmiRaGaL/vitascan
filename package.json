{
  "name": "vitascan",
  "private": true,
  "version": "0.1.0",
  "dependencies": {
    "@vitascan/shared": "workspace:*"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "dev:web": "pnpm --filter @vitascan/web dev",
    "dev:api": "pnpm --filter @vitascan/api build && pnpm --filter @vitascan/api start:dev",
    "dev:mobile": "pnpm --filter @vitascan/mobile start",
    "dev": "concurrently \"pnpm dev:web\" \"pnpm dev:api\"",
    "build:shared": "pnpm --filter @vitascan/shared build",
    "build:api": "pnpm --filter @vitascan/api build",
    "build": "pnpm build:shared && pnpm build:api && pnpm --filter @vitascan/web build",
    "test": "pnpm --filter @vitascan/api test",
    "lint": "pnpm --filter @vitascan/web lint",
    "typecheck": "pnpm --filter @vitascan/web exec tsc --noEmit",
    "ci": "pnpm build && pnpm test && pnpm lint && pnpm typecheck"
  }
}
